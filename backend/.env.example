# CompliAGL Backend — Environment Variables
APP_NAME=CompliAGL
APP_VERSION=0.1.0
DEBUG=true
DATABASE_URL=sqlite:///./compliagl.db
SECRET_KEY=change-me-to-a-random-secret

# ── x402 payment execution adapter ──────────────────────────────────
# Facilitator endpoint used to verify payments. Leave empty or set to
# "mock" to use the built-in mock facilitator during local development.
X402_FACILITATOR_URL=
# Address that should receive the x402 payment.
X402_RECIPIENT_ADDRESS=
# Price (in USDC) required to authorise an autonomous action.
X402_PRICE_USDC=0.0
# Network the payment is expected to settle on.
X402_NETWORK=base-sepolia
